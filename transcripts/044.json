  },
  {
   "start": 182.92,
   "end": 183.7,
   "text": "Haley Joel.",
   "speaker": "S06"
  },
  {
   "start": 184.18,
   "end": 186.46,
   "text": "Oh, boy, you're so young, Josie, look at you.",
