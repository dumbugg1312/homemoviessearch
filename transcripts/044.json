  },
  {
   "start": 71.2,
   "end": 74.16,
   "text": "Now the wizard is hungry.",
   "speaker": "S174"
  },
  {
   "start": 75.84,
   "end": 78.78,
   "text": "Make some pies, make them for me.",
   "speaker": "S174"
  },
  {
   "start": 80.36,
   "end": 81.74,
   "text": "Yes, my master, that sounds good.",
   "speaker": "S06"
  },
  {
   "start": 81.82,
