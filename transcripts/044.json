  },
  {
   "start": 237.48,
   "end": 238.24,
   "text": "It's good.",
   "speaker": "S06"
  },
  {
   "start": 238.5,
   "end": 239.6,
   "text": "Okay, I heard cow.",
   "speaker": "S58"
  },
  {
   "start": 240.06,
