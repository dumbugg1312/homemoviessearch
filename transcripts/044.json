  },
  {
   "start": 150.48,
   "end": 150.92,
   "text": "A lot of it.",
   "speaker": "S05"
  },
  {
   "start": 151.08,
   "end": 151.76,
   "text": "Are you getting this, Brendon?",
   "speaker": "S05"
  },
  {
   "start": 152.3,
