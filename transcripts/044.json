  },
  {
   "start": 214.56,
   "end": 214.8,
   "text": "What?",
   "speaker": "S06"
  },
  {
   "start": 214.92,
   "end": 215.22,
   "text": "You know?",
   "speaker": "S06"
  },
  {
   "start": 215.38,
   "end": 216.1,
   "text": "What do you mean, maybe?",
   "speaker": "S06"
  },
  {
   "start": 216.22,
   "end": 218.4,
   "text": "No, no, no, Brendon, we've already sunk two months into it.",
   "speaker": "S05"
  },
  {
   "start": 218.46,
   "end": 220.62,
   "text": "That's three times longer than we sunk anything before.",
   "speaker": "S05"
  },
  {
   "start": 220.84,
   "end": 221.84,
   "text": "No, you know, I know.",
   "speaker": "S06"
  },
  {
   "start": 221.98,
   "end": 223.48,
   "text": "You're not abandoning ship, are you?",
   "speaker": "S22"
  },
  {
   "start": 223.64,
   "end": 225.52,
   "text": "No, no, no, no.",
   "speaker": "S06"
  },
  {
   "start": 226.42,
   "end": 226.74,
   "text": "Okay.",
   "speaker": "S06"
  },
  {
   "start": 227.22,
   "end": 228.22,
   "text": "Brendon, next step.",
   "speaker": "S22"
  },
  {
   "start": 229.0,
   "end": 229.32,
   "text": "Investors.",
   "speaker": "S22"
  },
  {
   "start": 229.56,
   "end": 230.56,
   "text": "We do have a good product.",
   "speaker": "S22"
  },
  {
   "start": 230.78,
   "end": 232.02,
   "text": "All we need is the people to give money.",
   "speaker": "S22"
  },
  {
   "start": 232.02,
   "end": 232.62,
   "text": "Hmm.",
   "speaker": "S151"
  },
  {
   "start": 233.56,
