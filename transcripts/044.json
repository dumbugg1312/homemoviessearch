   "speaker": "S22"
  },
  {
   "start": 45.86,
   "end": 50.06,
   "text": "I am a baker, and today is my birthday.",
   "speaker": "S90"
  },
  {
   "start": 50.4,
   "end": 53.78,
   "text": "And I just turned one years old.",
   "speaker": "S90"
  },
  {
   "start": 53.96,
   "end": 57.82,
   "text": "And I'm very cold, cause I just found out I'm a baker, man.",
   "speaker": "S90"
  },
  {
   "start": 57.82,
   "end": 62.98,
   "text": "And I live inside a baking can with soft and pretty baker's hands.",
   "speaker": "S90"
  },
  {
   "start": 63.16,
   "end": 66.72,
   "text": "And I'm also me.",
